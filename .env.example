# FastAPI gateway (api/). Start: cd api && uvicorn app.main:app --reload --port 8000
VITE_API_URL=http://localhost:8000

# IVF dashboard: read real Google Sheet via API (needs credentials + api running).
VITE_SHEET_USE_API=true

# Dentrix sync: launches scraper.py on the API machine (Playwright + Chromium).
VITE_DENTRIX_SYNC_USE_API=true
