PORT=8000
# Path to the Excel workbook (created automatically if missing)
EXCEL_PATH=data/plan_catalog.xlsx
# false = simulated portal (default for CSE499 demos)
# true = use Playwright when portal_scraper implements it
USE_PLAYWRIGHT=false
# Comma-separated origins for CORS (Vite default shown)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
