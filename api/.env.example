PORT=8000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Google Sheet (paths relative to repo root when running uvicorn from api/)
GOOGLE_CREDENTIALS_FILE=credentials/google_credentials.json
GOOGLE_SHEET_NAME=test_excel
GOOGLE_WORKSHEET_NAME=Sheet1

# Force in-memory mock even if credentials exist:
# SHEET_USE_STUB=true

# Force robot stub (no Playwright):
# ROBOT_USE_STUB=true
# DENTRIX_SCHEDULE_URL=https://live19.dentrixascend.com/pm#/schedule/calendar
# PLAYWRIGHT_USER_DATA_DIR=user_data
# ROBOT_TEST_PATIENT_LIMIT=3
